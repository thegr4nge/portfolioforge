# PortfolioForge Outreach — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# Apollo.io API key — https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=

# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Exa.ai API key — https://dashboard.exa.ai/api-keys
EXA_API_KEY=

# Reddit API — https://www.reddit.com/prefs/apps (create a "script" app)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# Gmail — use an App Password (not your account password)
# Generate at: myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=
